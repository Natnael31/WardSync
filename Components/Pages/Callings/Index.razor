@page "/callings"
@rendermode InteractiveServer
@inject WardSyncService Service
@inject NavigationManager Navigation

<h1>Calling Tracker</h1>

<div style="margin-bottom: 1rem;">
    <button class="btn-primary" @onclick="NavigateToCreate">+ Add New Calling</button>
    <button class="btn-secondary" @onclick="RefreshData" style="margin-left: 0.5rem;">Refresh</button>
</div>

@if (isLoading)
{
    <div class="loading">
        <p>Loading callings...</p>
    </div>
}
else if (errorMessage != null)
{
    <div class="alert alert-danger">
        <p><strong>Error:</strong> @errorMessage</p>
    </div>
}
else if (callings.Any())
{
    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Title</th>
                    <th>Organization</th>
                    <th>Member</th>
                    <th>Status</th>
                    <th>Follow-Up</th>
                    <th>Date Extended</th>
                    <th>Date Sustained</th>
                    <th>Date Released</th>
                    <th>Notes</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var calling in callings)
                {
                    <tr>
                        <td>@calling.Id</td
                        <td>@calling.Title</td
                        <td>@calling.Organization</td
                        <td>@calling.MemberAssigned</td
                        <td>@calling.Status</td
                        <td>@(calling.NeedsFollowUp ? "Yes" : "No")</td
                        <td>@(calling.DateExtended?.ToString("yyyy-MM-dd") ?? "-")</td
                        <td>@(calling.DateSustained?.ToString("yyyy-MM-dd") ?? "-")</td
                        <td>@(calling.DateReleased?.ToString("yyyy-MM-dd") ?? "-")</td
                        <td>@calling.Notes</td
                        <td>
                            <button class="btn-edit" @onclick="() => NavigateToEdit(calling.Id)">Edit</button>
                            <button class="btn-delete" @onclick="() => DeleteCalling(calling.Id)">Delete</button>
                         </td
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="alert alert-info">
        <small>Total callings: @callings.Count</small>
    </div>
}
else
{
    <div class="empty-state">
        <p>No callings found. Click "Add New Calling" to get started!</p>
        <p><small>Make sure your database has been created and migrations have been applied.</small></p>
    </div>
}

@if (showDeleteConfirmation)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <h3>Confirm Delete</h3>
            <p>Are you sure you want to delete this calling?</p>
            <p><strong>@callingToDelete?.Title</strong> - @callingToDelete?.Organization</p>
            <div style="display: flex; gap: 0.5rem; margin-top: 1rem;">
                <button class="btn-delete" @onclick="ConfirmDelete">Yes, Delete</button>
                <button class="btn-secondary" @onclick="CancelDelete">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    private List<Calling> callings = new();
    private Calling? callingToDelete = null;
    private bool showDeleteConfirmation = false;
    private bool isLoading = true;
    private string? errorMessage = null;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadData();
        }
    }

    private async Task RefreshData()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            StateHasChanged();
            
            callings = await Service.GetCallingsAsync();
                        
            isLoading = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            isLoading = false;
            StateHasChanged();
        }
    }

    private void NavigateToCreate()
    {
        Navigation.NavigateTo("/callings/create");
    }

    private void NavigateToEdit(int id)
    {
        Navigation.NavigateTo($"/callings/edit/{id}");
    }

    private void DeleteCalling(int id)
    {
        callingToDelete = callings.FirstOrDefault(c => c.Id == id);
        showDeleteConfirmation = true;
        StateHasChanged();
    }

    private async Task ConfirmDelete()
    {
        if (callingToDelete != null)
        {
            await Service.DeleteCallingAsync(callingToDelete.Id);
            showDeleteConfirmation = false;
            callingToDelete = null;
            await LoadData();
        }
    }

    private void CancelDelete()
    {
        showDeleteConfirmation = false;
        callingToDelete = null;
        StateHasChanged();
    }
}